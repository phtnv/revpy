// Basic non-streaming route roundtrip.
// Field names are intentionally unquoted so this stays pleasant to edit by hand.
{
    name: "basic_text_conversion",

    config: {
        model: "claude-test-model",
        max_tokens: 1024,
    },

    // What an OpenAI-compatible client sends to this proxy.
    openai_request: {
        model: "ignored-by-proxy",
        max_tokens: 256,
        messages: [
            {
                role: "system",
                content: "You are helpful.",
            },
            {
                role: "user",
                content: "Hello.",
            },
        ],
    },

    // What the fake Anthropic client should receive from the proxy.
    expected_anthropic_request: {
        model: "claude-test-model",
        max_tokens: 256,
        system: [
            {
                type: "text",
                text: "You are helpful.",
            },
        ],
        messages: [
            {
                role: "user",
                content: "<OOC>\nBegin the scenario.\n</OOC>\nHello.",
            },
        ],
    },

    // What the fake Anthropic client returns to the proxy.
    anthropic_response: {
        id: "msg_test",
        stop_reason: "end_turn",
        content: [
            {
                type: "text",
                text: "Hi there.",
            },
        ],
        usage: {
            input_tokens: 10,
            output_tokens: 3,
            cache_creation_input_tokens: 0,
            cache_read_input_tokens: 0,
        },
    },

    // What the OpenAI-compatible caller should receive from the proxy.
    expected_openai_response: {
        id: "msg_test",
        object: "chat.completion",
        created: 1234567890,
        model: "anthropic/claude-test-model",
        choices: [
            {
                index: 0,
                finish_reason: "end_turn",
                message: {
                    role: "assistant",
                    content: "Hi there.",
                    anthropic_content: [
                        {
                            type: "text",
                            text: "Hi there.",
                        },
                    ],
                    anthropic_thinking_preserved: false,
                },
            },
        ],
        usage: {
            prompt_tokens: 10,
            completion_tokens: 3,
            total_tokens: 13,
            input_tokens_uncached: 10,
            cache_creation_input_tokens: 0,
            cache_read_input_tokens: 0,
        },
    },
}
